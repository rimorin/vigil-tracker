# Vigil — environment variables
# Copy this file to .env and fill in your values, or just run: bash install.sh
# The install wizard will prompt for required values and write them for you.

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# SMTP email
# ---------------------------------------------------------------------------
# Works with any email provider — no third-party service account required.
#
# Common providers:
#   Gmail:              SMTP_HOST=smtp.gmail.com       SMTP_PORT=587
#   Outlook / M365:     SMTP_HOST=smtp.office365.com   SMTP_PORT=587
#   Fastmail:           SMTP_HOST=smtp.fastmail.com    SMTP_PORT=587
#   Apple iCloud:       SMTP_HOST=smtp.mail.me.com     SMTP_PORT=587
#
# Gmail users: use an App Password, not your account password.
#   Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# SMTP_FROM is optional — defaults to SMTP_USER if not set.
# SMTP_FROM=you@gmail.com

# Comma-separate to send to multiple recipients (e.g. you + accountability partner)
SMTP_TO=you@example.com

# ---------------------------------------------------------------------------
# Schedule — controls when the digest email is sent
# ---------------------------------------------------------------------------
# SUMMARY_SCHEDULE: hourly | daily | weekly | monthly | interval
SUMMARY_SCHEDULE=daily

# Time of day for the trigger (used by daily / weekly / monthly)
SUMMARY_SCHEDULE_HOUR=21      # 0-23
SUMMARY_SCHEDULE_MINUTE=0     # 0-59

# Day of week for weekly schedule (mon | tue | wed | thu | fri | sat | sun)
SUMMARY_SCHEDULE_WEEKDAY=mon

# Day of month for monthly schedule (1-28)
SUMMARY_SCHEDULE_DAY=1

# Number of minutes between digests — used when SUMMARY_SCHEDULE=interval
SUMMARY_SCHEDULE_INTERVAL_MINUTES=30

# ---------------------------------------------------------------------------
# Log retention
# ---------------------------------------------------------------------------
# Activity log entries older than this many days are automatically pruned.
# Set to 0 to disable cleanup entirely.
LOG_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Adult content alerts
# ---------------------------------------------------------------------------
# Real-time alerts (macOS notification + email) when a porn/adult site is visited.
# Detection is fully offline: a curated domain blocklist + keyword matching.
# All values below are optional — the defaults shown are used if not set.

# Master switch — set to false to disable all adult alerts.
ADULT_ALERT_ENABLED=true

# Minutes before the same domain can trigger another alert (prevents spam).
ADULT_ALERT_COOLDOWN_MINUTES=30

# Fire a macOS banner notification immediately when an adult site is detected.
ADULT_ALERT_NOTIFICATION=true

# Send an alert email via the SMTP settings above.
ADULT_ALERT_EMAIL=true

# ---------------------------------------------------------------------------
# Schedule examples
# ---------------------------------------------------------------------------
# Every 30 minutes         → SUMMARY_SCHEDULE=interval  SUMMARY_SCHEDULE_INTERVAL_MINUTES=30
# Every hour at :00        → SUMMARY_SCHEDULE=hourly
# Every day at 9 PM        → SUMMARY_SCHEDULE=daily     SUMMARY_SCHEDULE_HOUR=21
# Every Monday at 8 AM     → SUMMARY_SCHEDULE=weekly    SUMMARY_SCHEDULE_WEEKDAY=mon  SUMMARY_SCHEDULE_HOUR=8
# 1st of each month at 9AM → SUMMARY_SCHEDULE=monthly   SUMMARY_SCHEDULE_DAY=1        SUMMARY_SCHEDULE_HOUR=9
